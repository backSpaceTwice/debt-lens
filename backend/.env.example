# Copy this file to .env and fill in your values. .env is gitignored.

# GitHub personal access token. Two uses:
#   - Analysis (read): raises GitHub's rate limit from 60 to 5000 req/hour.
#     Read-only access to public repositories is enough.
#   - Auto-fix "Apply" (write): pushes the fix to a branch on the repo and
#     returns a compare/PR URL. This requires WRITE access — scope `repo`
#     (classic token) or `public_repo` for public repos only (or a
#     fine-grained token with Contents: read & write on the target repo).
#     You can only push to repos this token can write to (i.e. yours / a fork);
#     for repos you don't own, Apply falls back to downloading the fixed file.
# If unset, analysis still works (rate-limited) and Apply falls back to download.
GITHUB_TOKEN=

# Used in Step 2+ for Anthropic API calls. Not needed for Step 1.
ANTHROPIC_API_KEY=
