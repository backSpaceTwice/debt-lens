# Copy this file to .env and fill in your values. .env is gitignored.

# Optional: raises GitHub's rate limit from 60 to 5000 req/hour.
# Public-repo MVP needs no scopes — a fine-grained token with read-only
# access to public repositories is enough.
GITHUB_TOKEN=

# Used in Step 2+ for Anthropic API calls. Not needed for Step 1.
ANTHROPIC_API_KEY=
